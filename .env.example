# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=ugram_health
POSTGRES_USER=ugram
POSTGRES_PASSWORD=change_me_in_production

# ── MinIO ─────────────────────────────────────────────────
MINIO_ROOT_USER=ugram-admin
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_BUCKET_NAME=ugram-files

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=super-secret-key-change-in-production-must-be-at-least-64-chars-long-for-hs512
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── Application ──────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
